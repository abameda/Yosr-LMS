# Yosr environment contract
# Copy this file to .env.local for local development. Keep secret values blank
# in this tracked template and obtain real non-production values from an owner.

# Application runtime. Staging and production use fixed canonical APP_URL
# values. A Vercel preview may omit APP_URL only when it derives the effective
# URL from the enabled VERCEL_BRANCH_URL system variable.
APP_ENV=local
APP_URL=http://localhost:3000

# Browser-safe Supabase configuration: required in every running application.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Prisma 7 database configuration.
# Runtime Prisma Client construction consumes the pooled DATABASE_URL.
# The Stage 1 prisma.config.ts will load dotenv and map datasource.url to
# DIRECT_URL.
DATABASE_URL=
DIRECT_URL=

# Optional: required only for cloud-development migration workflows that need a
# dedicated shadow database. The Stage 1 prisma.config.ts will map
# datasource.shadowDatabaseUrl to this value. Never point it at development,
# staging, or production data.
SHADOW_DATABASE_URL=

# Optional: read only by server code that performs an explicitly approved
# privileged Supabase operation.
SUPABASE_SECRET_KEY=

# Email remains disabled until its Stage 0/1 entry point is implemented.
# Set EMAIL_PROVIDER=resend only where Resend delivery is intentionally active.
EMAIL_PROVIDER=disabled
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Error monitoring remains disabled until the Sentry baseline is implemented.
# DSN presence activates its corresponding server or browser SDK. The browser
# DSN is public by design. Prefer CI or the Sentry Vercel integration for source
# maps; application runtime code must never read SENTRY_AUTH_TOKEN.
SENTRY_ENABLED=false
SENTRY_ENVIRONMENT=local
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Test-only configuration.
# Unit tests require no credentials. Database integration tests must use a
# dedicated non-production database; browser tests target E2E_BASE_URL.
TEST_DATABASE_URL=
E2E_BASE_URL=

# R2, payment-provider, and video-provider variables are intentionally absent.
# Add them only after the corresponding readiness gate is approved.
